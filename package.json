{
  "name": "car-repair-center",
  "version": "1.0.0",
  "description": "El Ansary Car Service Shop Management System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.elansary.shopmanager",
    "productName": "El Ansary Shop Manager",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "**/*",
      "!node_modules/electron-rebuild/**",
      "!node_modules/electron-builder/**"
    ],
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "database/",
        "to": "database/"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmeeeeedddddd/Service-Shop.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ahmeeeeedddddd/Service-Shop/issues"
  },
  "homepage": "https://github.com/ahmeeeeedddddd/Service-Shop#readme",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "csv-parse": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9"
  }
}
